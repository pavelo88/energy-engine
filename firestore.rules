rules_version = '2'; 

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // NOTE: The isAdmin function and other role-based checks were not working
    // because the user documents were not being created with the auth UID as the document ID.
    // The rules below are simplified to allow any signed-in user to access the admin
    // collections. This is a temporary measure for development to unblock the UI.
    // For production, a robust role-check system must be implemented.
    function isAdmin() {
        return isSignedIn();
    }
     function isAnyRole() {
      return isSignedIn();
    }
     function isManagement() {
      return isSignedIn();
    }

    // ------------------------------------------------------------------------
    // Admin Panel Collections - Simplified Rules for Development
    // ------------------------------------------------------------------------
    
    match /clientes/{clienteId} {
      allow read, write: if isSignedIn();
    }

    match /usuarios/{usuarioId} {
      allow read, write: if isSignedIn();
    }

    match /trabajos/{trabajoId} {
      allow read, write: if isSignedIn();
    }

    match /gastos/{gastoId} {
      allow read, write: if isSignedIn();
    }
    
    // ------------------------------------------------------------------------
    // Original "AssetTrack AI" Rules (kept for reference, may not be used)
    // ------------------------------------------------------------------------
    match /web_content/{configId} {
      allow get, list: if true;
      allow create, update, delete: if false; // Only allow read for public content
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /assets/{assetId} {
      allow get, list: if isAnyRole();
      allow create, update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow get: if isManagement() || (resource.data.technicianId == request.auth.uid);
      allow list: if isAnyRole();
      allow create: if resource.data.technicianId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false; // Protect audit trail
    }

     match /reports/{reportId}/multimedia/{multimediaId} {
        allow get, list: if isManagement() || (resource.data.reportOwnerId == request.auth.uid);
        allow create: if request.resource.data.reportOwnerId == request.auth.uid;
        allow update, delete: if resource.data.reportOwnerId == request.auth.uid;
      }

    match /global_stats/{configId} {
      allow get, list: if isManagement();
      allow write: if false; // Should be updated by cloud functions
    }
  }
}
